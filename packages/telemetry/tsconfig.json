{
  "compilerOptions": {
    "lib": [
      "esnext",
      "DOM"
    ],
    "allowJs": false,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "types": [
      "cypress"
    ],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true
  }
}
