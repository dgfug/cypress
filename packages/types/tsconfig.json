{
  "include": [
    "src/*.ts",
    "src/**/*.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "allowJs": true,
    "noUncheckedIndexedAccess": true,
    "ignoreDeprecations": "5.0",
    "importsNotUsedAsValues": "error",
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "types": [
      "mocha",
      "node"
    ]
  }
}