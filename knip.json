      "project": [
        "lib/**/*.{ts,js}",
        "scripts/**/*.{ts,js}",
        "types/**/*.ts"
      ],
      "ignoreDependencies": [
        "buffer",
        "process"
      ]
    },
    "packages/app": {
      "entry": [
        "src/main.ts",
        "src/router/router.ts",
        "src/pages/**/*.vue",
        "src/layouts/**/*.vue",
        "src/**/*.cy.{ts,tsx,js,jsx}",
        "src/generated/**/*.ts",
        "cypress/**/*.{ts,tsx,js,jsx}",
        "cypress.config.ts"
