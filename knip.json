        "**/*.{ts,tsx,js,jsx}",
        "*.{ts,tsx,js,jsx}"
      ],
      "ignoreDependencies": [
        "buffer",
        "process",
        "@babel/plugin-transform-class-properties",
        "@babel/plugin-transform-object-rest-spread",
        "babel-plugin-add-module-exports",
        "@paths/.+"
