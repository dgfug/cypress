        "script/**/*.{ts,tsx,js,jsx}",
        "*.{ts,tsx,js,jsx,mjs}"
      ]
    },
    "packages/server": {
      "entry": [
        "start-cypress.js",
        "lib/cypress.ts",
        "lib/modes/**/*.ts",
        "lib/browsers/**/*.ts",
        "lib/capture.ts",
        "lib/runner-ct.ts",
        "lib/cloud/artifacts/upload_artifacts.ts",
        "lib/cloud/network/nonretriable_cert_error_codes.ts",
        "lib/plugins/child/default_plugins_file.js",
        "lib/privileged-commands/privileged-channel.js",
