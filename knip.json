    "packages/config": {
      "project": [
        "src/**/*.{ts,tsx,js,jsx}"
      ],
      "ignoreDependencies": [
        "@babel/parser",
        "@babel/plugin-syntax-typescript",
        "@babel/plugin-transform-typescript"
