      "project": [
        "lib/**/*.{ts,tsx,js,jsx}",
        "test/**/*.{ts,tsx,js,jsx}",
        "*.{ts,tsx,js,jsx}"
      ],
      "ignoreDependencies": [
        "@babel/core",
        "@babel/preset-env",
        "babel-loader"
      ]
    },
