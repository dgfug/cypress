{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": [
        "gulpfile.js"
      ]
    },
    "cli": {
      "entry": [
        "bin/cypress",
        "lib/bin/cypress.ts",
        "lib/index.ts",
        "lib/cli.ts",
        "scripts/**/*.{ts,js}",
        "types/tests/**/*.ts"
